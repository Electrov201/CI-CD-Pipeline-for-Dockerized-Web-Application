# =============================================================
#  .env.example — Environment Variable Template (HTTP-Only)
#
#  Copy this file to .env on your EC2 instance and fill in
#  the actual values. NEVER commit .env to Git.
#
#  cp .env.example .env && nano .env
# =============================================================

# Your GitHub username / GitHub repository (lowercase)
# Format: github-username/docker-github-actions-cicd
GITHUB_REPOSITORY=your-username/docker-github-actions-cicd
